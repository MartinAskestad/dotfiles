" ## Basics
set nocompatible                                                                " Not compatible with VI
set showcmd
filetype plugin indent on                                                       " Add filetype, plugin, indent support
syntax on                                                                       " Turn on syntax highlighting

" ## Settings
set backspace=indent,eol,start                                                  " Allow to backspace everything in insert mode
set wildmenu                                                                    " Display matches in command-line mode
set expandtab                                                                   " Prefer tabs over spaces
set tabstop=2 softtabstop=2                                                     " Set tab size to 2
set shiftwidth=2
set smartindent
set tabstop=2 softtabstop=2                                                     " Set tab size to 2
set shiftwidth=2
set smartindent
set hidden                                                                      " Prefer hiding over unloading buffers
set path=.,**                                                                   " Relative to current file and everything under :pwd
setl wildignore=**/node_modules/**,**/dist/**
set noswapfile
let mapleader = " "                                                             " Space as <leader>
set encoding=utf-8
set fileencoding=utf-8
set ruler                                                                       " Show cursor position at all times
set cursorline                                                                  " Highlight current line
set cursorlineopt=line
set cmdheight=2                                                                 " more space for displaying messages
set splitbelow splitright
set t_Co=256
set laststatus=2                                                                " Always show status line
set showtabline=2                                                               " Always show tab line
set updatetime=300
set timeoutlen=1000
set clipboard=unnamed
set colorcolumn=80
set scrolloff=5
set pumheight=10
set nowrap
set switchbuf=usetab,newtab

" Change to project dir when opening certain files
let g:autochdir_project = 1

" ## Plugins
colorscheme PaperColor

" vim-which-key
packadd vim-which-key
nnoremap <silent> <leader> :<C-u>WhichKey '<Space>'<CR>
vnoremap <silent> <leader> :<C-u>WhichKeyVisual '<Space>'<CR>
let g:which_key_map = {} 
call which_key#register('<Space>', 'g:which_key_map')

" Configure lightline
let g:lightline = {
  \ 'colorscheme': 'PaperColor',
  \ 'active': {
  \   'left': [ [ 'mode', 'paste' ],
  \             [ 'gitbranch', 'readonly', 'filename', 'modified' ] ]
  \   },
  \ 'component_function': { 'gitbranch': 'FugitiveHead' }
  \ } 

" Configure vim-lsp
set foldmethod=manual
set foldexpr=lsp#ui#vim#folding#foldexpr()
set foldtext=lsp#ui#vim#folding#foldtext()

" Configure asyncomplete
let g:asyncomplete_auto_completeopt = 0
set completeopt=menuone,noinsert

" vim-signify
let g:signify_sign_show_count = 0
let g:which_key_map['g'] = {
  \ 'name': '+git',
  \ 'j': 'Next hunk',
  \ 'k': 'Previous hunk',
  \ }
nmap <leader>gj <plug>(signify-next-hunk)
nmap <leader>gk <plug>(signify-prev-hunk)

" vim-vsnip
let g:vsnip_snippet_dir = expand('$HOME/.local/vim-vsnip')
imap <expr> <C-l> vsnip#available(1) ? '<Plug>(vsnip-expand-or-jump)' : '<C-l>'
smap <expr> <C-l> vsnip#available(1) ? '<Plug>(vsnip-expand-or-jump)' : '<C-l>'


" ## Keyboard mappings
vnoremap . :        " Period is easier to reach on swedish keyboard
vnoremap : .
nnoremap . :
nnoremap : .

" Natural line jumping over wrapped lines
nnoremap j gj
nnoremap k gk
vnoremap j gj
vnoremap k gk

" Set up keybindings for asyncomplete
inoremap <expr> <Down> pumvisible() ? "\<C-n>" : "\<Down>"
inoremap <expr> <Up>   pumvisible() ? "\<C-p>" : "\<Up>"
inoremap <expr> <CR>   pumvisible() ? asyncomplete#close_popup() : "\<CR>"
inoremap <expr> <Tab>  pumvisible() ? asyncomplete#close_popup() : "\<Tab>"
inoremap <expr> <Left> pumvisible() ? asyncomplete#cancel_popup() : "\<Left>"

" Windows
let g:which_key_map['w'] = {
  \ 'name': '+windows',
  \ 'w': ['<C-w>w', 'Other window'],
  \ 'q': ['<C-w>c', 'Close window'],
  \ 's': ['<C-w>s', 'Split window below'],
  \ 'v': ['<C-w>v', 'Split  window right'],
  \ 'h': ['<C-w>h', 'Window left'],
  \ 'j': ['<C-w>j', 'Window below'],
  \ 'k': ['<C-w>k', 'Window above'],
  \ 'l': ['<C-w>l', 'Window right'],
  \ 'H': ['<C-w>5<', 'Expand window left'],
  \ 'J': [':resize +5', 'Expand window down'],
  \ 'K': [':resize -5', 'Expand window up'],
  \ 'L': ['<C-w>5>', 'Expand window right'],
  \ 'b': ['<C-w>=', 'Balance window'],
  \ }

" Tabs
let g:which_key_map['t'] = {
  \ 'name': '+tabs',
  \ 't': [':tab sball', 'Open all buffers in tabs'],
  \ 'h': [':tabprevious', 'Previous tab'],
  \ 'j': [':tabmove -1', 'Move tab left'],
  \ 'k': [':tabmove +1', 'Move tab right'],
  \ 'l': [':tabnext', 'Next tab'],
  \ 'H': [':tabfirst', 'First tab'],
  \ 'L': [':tablast', 'Last tab'],
  \ 'q': [':bdelete', 'Close tab'],
  \ 'Q': [':bdelete!', 'Close tab discard changes'],
  \ 'o': 'Open new tab',
  \ }
noremap <leader>to :tabnew<SPACE>

let g:which_key_map['l'] = {
  \ 'name': '+Language server',
  \ 'd': 'Definitions',
  \ 's': 'Document symbol search',
  \ 'S': 'Workspace symbol search',
  \ 'r': 'References',
  \ 'rn': 'Rename',
  \ 'j': 'Next diagnostic',
  \ 'k': 'Previous diagnostic',
  \ ',': 'Hover',
  \ '.': 'Code action',
  \ 'o': 'Document symbols',
  \ }
nnoremap <buffer> <leader>ld :tab LspDefinition<CR>
nnoremap <buffer> <leader>ls :LspDocumentSymbolSearch<CR>
nnoremap <buffer> <leader>lS :LspWorkspaceSymbolSearch<CR>
nnoremap <buffer> <leader>lr :LspReferences<CR>
nnoremap <buffer> <leader>lrn :LspRename<CR>
nnoremap <buffer> <F2>       :LspRename<CR>
nnoremap <buffer> <leader>lj :LspNextDiagnostic<CR>
nnoremap <buffer> <leader>lk :LspPreviousDiagnostic<CR>
nnoremap <buffer> <leader>l,  :LspHover<CR>
nnoremap <buffer> <leader>l.  :LspCodeAction<CR>
nnoremap <buffer> <leader>o :LspDocumentSymbol

